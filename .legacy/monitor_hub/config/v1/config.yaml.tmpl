# Code generated by hzx generator.
# monitor_hub service config
# 默认服务配置, hzx会根据该模板生成对应的config.go文件, 如需修改结构请再此修改，并运行hzx update config 重新生成
hertz_server:
  # 默认http端口
  http_port: 8081
  # pprof性能分析端口 0 表示不启用
  pprof_port: 6060
  # tcp 长连接保活时间，一般情况下不用修改，更应该关注 idleTimeout
  keep_alive_timeout: 60
  # 长连接请求链接空闲超时时间 秒 默认3min
  idle_timeout: 180
  # 底层读取数据超时时间 秒 默认3min
  read_timeout: 180
  # 配置最大的请求体大小 默认 4 _ 1024 _ 1024
  max_request_body_size: 4194304
  # 如果开启，则会使用流式处理 body
  stream_body: false
  # 设置优雅退出时间。
  # Server 会停止建立新的连接，并对关闭后的每一个请求设置 Connection: Close 的 header，当到达设定的时间关闭 Server。
  # 当所有连接已经关闭时，Server 可以提前关闭
  exit_wait_time: 10
  # 设置回收时保留的请求体和响应体的最大大小。单位：字节 4 _ 1024 _ 1024
  max_keep_body_size: 4194304
  # 如果开启则使用 HTTP 长连接
  keep_alive: true
  # 设置读缓冲区大小，同时限制 HTTP header 大小 4 * 1024
  read_buffer_size: 4096
mongodb:
  # 是否启用mongodb
  enable: true
  # mongodb uri
  uri: ""
  # 是否启用w_majority
  w_majority: false
  # mongodb 连接池大小
  pool_size: 100
  dbname: "next"
  # mongodb 索引, 示例索引, 请根据实际情况修改
  indexes:
    - collection: datasource
      #冒号后面是value，不填默认是1 @后面是unique
      keys:
        - markDeleted,createdAt:-1,_id:-1@false
        - app_id,name,markDeleted,createdAt:-1,_id:-1@false
        - name,markDeleted,createdAt:-1,_id:-1@false
        - app_id,markDeleted,createdAt:-1,_id:-1@false
consul:
  # 是否启用consul
  enable: false
  # consul地址
  address: "localhost:8500"
  # consul 服务名称
  service_name: "monitor_hub"
  # weight 权重
  weight: 10
  # HealthCheck
  health_check:
    timeout: "10s"
    interval: "10s"
    deregister_critical_service_after: "30s"
websocket:
  # 是否启用WebSocket
  enable: true
  # WebSocket 写入超时时间（秒）
  write_wait: 10
  # Pong 消息等待时间（秒），超过此时间未收到 Pong 则认为连接断开
  pong_wait: 60
  # Ping 消息发送间隔（秒），必须小于 pong_wait
  ping_period: 54
  # 最大消息大小（字节），默认 1MB
  max_message_size: 1048576
  # 读缓冲区大小（字节），默认 4KB
  read_buffer_size: 4096
  # 写缓冲区大小（字节），默认 4KB
  write_buffer_size: 4096
  # 每个连接的发送队列缓冲大小（消息数量）
  send_channel_size: 256
  # Hub 注册通道缓冲大小
  register_channel_size: 10
  # Hub 注销通道缓冲大小
  unregister_channel_size: 10
  # Hub 广播通道缓冲大小
  broadcast_channel_size: 100
  broadcast_triggers: # 广播触发器配置（自动生成）
    # BEGIN AUTO-GENERATED BROADCAST_TRIGGERS
    datasource:
      options:
        - method: BroadcastDatasourceStatus
          topic: datasource.status
          trigger_type: interval
          interval: 10s
    points:
      options:
        - method: BroadcastPoints
          topic: points
          trigger_type: event
          event_buffer_size: 4096
          event_name: aggregation.*
trigger:
  datasource_status:
    interval: 10s
storage:
  type: prometheus
  data_dir: ./data
  retention_days: 7
  compaction_interval: 2h
  max_chunk_size: 536870912 # 512MB
  write_buffer_size: 4096 # 4MB
  mix_block_duration: 2h
  max_block_duration: 24h
  memory_cleanup_interval: 6h
aggregation:
  # 启用级联聚合
  enabled: true
  # 采集超时时间（应该小于最小聚合间隔，建议为最小间隔的 80%）
  collect_timeout: "12s"
  # 查询延迟（全局配置，用于等待迟到数据）
  # 说明：将当前时间向前移动指定时长后再查询，适用于日志采集等存在固定延迟的场景
  # 例如：日志 30s flush 一次，设置 60s 延迟（30s + 30s 缓冲）
  # 会导致图表延迟相应时间，但能避免数据断档
  query_delay: "60s"
  # 级联配置
  levels:
    # ==========================================
    # 实时监控级别 (15s)
    # ==========================================
    - name: "15s"
      interval: 15s
      retention: 30m
      source: "raw"
      min_points: 1
      fallback_mode: "skip"
      description: "实时监控级别：从 Pushgateway 采集原始数据，保留 30 分钟（120 个数据点）用于实时告警和问题定位"
    # ==========================================
    # 短期分析级别 (1m)
    # ==========================================
    - name: "1m"
      interval: 1m
      retention: 2h
      source: "15s"
      min_points: 4
      fallback_mode: "partial"
      description: "短期分析级别：从 15s 聚合（每分钟 4 个点），保留 2 小时（120 个数据点）用于短期趋势分析"
    # ==========================================
    # 当日分析级别 (5m)
    # ==========================================
    - name: "5m"
      interval: 5m
      retention: 12h
      source: "1m"
      min_points: 5
      fallback_mode: "partial"
      description: "当日分析级别：从 1m 聚合（每 5 分钟 5 个点），保留 12 小时（144 个数据点）用于当日性能分析"
    # ==========================================
    # 近期趋势级别 (30m)
    # ==========================================
    - name: "30m"
      interval: 30m
      retention: 24h
      source: "5m"
      min_points: 6
      fallback_mode: "partial"
      description: "近期趋势级别：从 5m 聚合（每 30 分钟 6 个点），保留 24 小时（48 个数据点）用于近期趋势对比"
    # ==========================================
    # 周级历史级别 (1h)
    # ==========================================
    - name: "1h"
      interval: 1h
      retention: 7d
      source: "30m"
      min_points: 2
      fallback_mode: "skip"
      description: "周级历史级别：从 30m 聚合（每小时 2 个点），保留 7 天（168 个数据点）用于周级趋势和容量规划"
    # ==========================================
    # 月级历史级别 (6h)
    # ==========================================
    - name: "6h"
      interval: 6h
      retention: 30d
      source: "1h"
      min_points: 6
      fallback_mode: "skip"
      description: "月级历史级别：从 1h 聚合（每 6 小时 6 个点），保留 30 天（120 个数据点）用于长期趋势和同比分析"
# 太湖网关认证配置
auth:
  # 是否启用认证（生产环境建议开启）
  enable: false
  # 太湖应用密钥（32字节，从太湖管理平台获取）
  taihu_key: "D9QOHPWPIKPWVHQE81G2UP0ZQYKSBXEG"
  # 安全模式：true=使用加密身份，false=使用明文身份（兼容模式）
  safe_mode: true
  # 签名过期时间（秒），默认 180 秒
  signature_expire: 180
  # Token 过期缓冲时间（分钟），默认 3 分钟
  token_expire_buffer: 3
taskpool:
  max_workers: 5
  task_timeout: 30m
  max_task_history: 1000
chunk_cache:
  max_size: 100
  default_ttl: 24h
