# Code generated by hzx generator.
# datasource service config
# 默认服务配置, hzx会根据该模板生成对应的config.go文件, 如需修改结构请再此修改，并运行hzx update config 重新生成
hertz_server:
  # 默认http端口
  http_port: 8082
  # pprof性能分析端口 0 表示不启用
  pprof_port: 6060
  # tcp 长连接保活时间，一般情况下不用修改，更应该关注 idleTimeout
  keep_alive_timeout: 60
  # 长连接请求链接空闲超时时间 秒 默认3min
  idle_timeout: 180
  # 底层读取数据超时时间 秒 默认3min
  read_timeout: 180
  # 配置最大的请求体大小 默认 4 _ 1024 _ 1024
  max_request_body_size: 4194304
  # 如果开启，则会使用流式处理 body
  stream_body: false
  # 设置优雅退出时间。
  # Server 会停止建立新的连接，并对关闭后的每一个请求设置 Connection: Close 的 header，当到达设定的时间关闭 Server。
  # 当所有连接已经关闭时，Server 可以提前关闭
  exit_wait_time: 10
  # 设置回收时保留的请求体和响应体的最大大小。单位：字节 4 _ 1024 _ 1024
  max_keep_body_size: 4194304
  # 如果开启则使用 HTTP 长连接
  keep_alive: true
  # 设置读缓冲区大小，同时限制 HTTP header 大小 4 * 1024
  read_buffer_size: 4096
mongodb:
  # 是否启用mongodb
  enable: false
  # mongodb uri
  uri: "mongodb://localhost:27017"
  # 是否启用w_majority
  w_majority: false
  # mongodb 连接池大小
  pool_size: 100
  dbname: "datasource"
  # mongodb 索引, 示例索引, 请根据实际情况修改
  indexes:
    - collection: user
      #冒号后面是value，不填默认是1 @后面是unique
      keys:
        - markDeleted,createdAt:-1,_id:-1@false
        - user_id,markDeleted,createdAt:-1,_id:-1@false
        - user_id,group,markDeleted,createdAt:-1,_id:-1@false
consul:
  # 是否启用consul
  enable: false
  # consul地址
  address: "localhost:8500"
  # consul 服务名称
  service_name: "datasource"
  # weight 权重
  weight: 10
  # HealthCheck
  health_check:
    timeout: "10s"
    interval: "10s"
    deregister_critical_service_after: "30s"
websocket:
  # 是否启用WebSocket
  enable: true
  # WebSocket 写入超时时间（秒）
  write_wait: 10
  # Pong 消息等待时间（秒），超过此时间未收到 Pong 则认为连接断开
  pong_wait: 60
  # Ping 消息发送间隔（秒），必须小于 pong_wait
  ping_period: 54
  # 最大消息大小（字节），默认 1MB
  max_message_size: 1048576
  # 读缓冲区大小（字节），默认 4KB
  read_buffer_size: 4096
  # 写缓冲区大小（字节），默认 4KB
  write_buffer_size: 4096
  # 每个连接的发送队列缓冲大小（消息数量）
  send_channel_size: 256
  # Hub 注册通道缓冲大小
  register_channel_size: 10
  # Hub 注销通道缓冲大小
  unregister_channel_size: 10
  # Hub 广播通道缓冲大小
  broadcast_channel_size: 100
storage:
  type: prometheus
  data_dir: ./data
  retention_days: 7
  compaction_interval: 2h
  max_chunk_size: 536870912 # 512MB
  write_buffer_size: 4096 # 4MB
  mix_block_duration: 2h
  max_block_duration: 24h
  memory_cleanup_interval: 6h
mark:
  # 聚合间隔
  aggregate_interval: 5s
  # 过期时间
  ttl: 5m
  # 通道大小
  channel_size: 51200
  # 清理间隔
  cleanup_interval: 15s
