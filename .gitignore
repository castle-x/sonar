# ============================================================
# Sonar Monorepo .gitignore
# ============================================================

# ------------------------------------------------------------
# OS & IDE
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

.idea/
.vscode/
*.swp
*.swo
*~

# ------------------------------------------------------------
# Go build artifacts
# ------------------------------------------------------------
bin/
*/bin/
sonar-tap/sonar-tap
sonar-store/sonar-store
sonar-view/sonar-view

# Go test cache & coverage
*.test
*.out
coverage.html
coverage.txt

# ------------------------------------------------------------
# Frontend build artifacts
# ------------------------------------------------------------
*/site/dist/
*/site/.vite/
*/site/.turbo/

# pnpm / npm
*/site/node_modules/
node_modules/

# ------------------------------------------------------------
# Data & Storage
# ------------------------------------------------------------
# Prometheus TSDB data (all locations)
**/data/
data/

# MongoDB data (local dev)
/tmp/mongodb-*/

# ------------------------------------------------------------
# Logs & Runtime artifacts
# ------------------------------------------------------------
*.log
*.pid
nohup.out

# Test e2e: compiled test binary only (keep scripts/configs/docs)
test/e2e/mock_gameserver
test/e2e/sonar-tap
test/e2e/sonar-store

# ------------------------------------------------------------
# OMC / Claude agent runtime state
# (keep .omc/ tracked but exclude volatile runtime files)
# ------------------------------------------------------------
**/.omc/state/
**/.omc/logs/
.omc/state/
.omc/logs/

# Playwright MCP browser profile (large, auto-generated)
.playwright-mcp/

# ------------------------------------------------------------
# Config secrets (never commit)
# ------------------------------------------------------------
*.secret.yaml
*.secret.json
.env
.env.*
!.env.example

# ------------------------------------------------------------
# Temporary / scratch files
# ------------------------------------------------------------
*.tmp
*.bak
scratch/
tmp/

# ------------------------------------------------------------
# What IS committed (explicit allowlist for clarity)
# ------------------------------------------------------------
# docs/             - all design, test cases, archive (document backup)
# test/e2e/*.md     - SOP, test cases, reports
# test/e2e/*.go     - mock_gameserver source
# test/e2e/*.yaml   - e2e test configs
# test/e2e/*.sh     - test scripts
# sonar-*/config/   - default config files
# api/              - Thrift IDL
# CLAUDE.md, AGENTS.md, README.md
